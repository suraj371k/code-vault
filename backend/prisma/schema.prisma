generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MEMBER
}

enum Language {
  // Web
  JAVASCRIPT
  TYPESCRIPT
  HTML
  CSS

  // Backend
  PYTHON
  JAVA
  CSHARP
  GO
  RUST
  RUBY
  PHP
  KOTLIN
  SWIFT
  SCALA
  ELIXIR
  HASKELL
  ERLANG
  CLOJURE

  // Systems
  C
  CPP
  ZIG
  ASM

  // Data / ML
  R
  MATLAB
  JULIA

  // Shell / DevOps
  BASH
  POWERSHELL
  DOCKERFILE
  YAML
  TOML

  // Database
  SQL
  PLSQL
  GRAPHQL

  // Mobile
  DART
  OBJC

  // Other
  LUA
  PERL
  GROOVY
  SOLIDITY
  VIM
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  memberships Membership[]
  snippets    Snippet[]

  groupMembers GroupMember[]

  messages            Message[]
  conversationMembers ConversationMember[]
}

model Organization {
  id        Int          @id @default(autoincrement())
  name      String
  createdAt DateTime     @default(now())
  slug      String?      @unique
  members   Membership[]
  snippets  Snippet[]
  groups    Group[]
}

model Membership {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id])
  userId Int

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId Int

  role Role @default(MEMBER)

  @@unique([userId, organizationId])
}

model Snippet {
  id Int @id @default(autoincrement())

  author   User @relation(fields: [authorId], references: [id])
  authorId Int

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId Int

  title      String
  code       String
  language   Language?
  category   String?
  summary    String[]
  tags       String[]
  created_at DateTime  @default(now())
}

model Message {
  id       Int    @id @default(autoincrement())
  content  String
  sender   User   @relation(fields: [senderId], references: [id])
  senderId Int

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId Int

  group     Group?   @relation(fields: [groupId], references: [id])
  groupId   Int?
  createdAt DateTime @default(now())
}

model Group {
  id           Int          @id @default(autoincrement())
  name         String
  organization Organization @relation(fields: [organizationId], references: [id])

  conversationId Int?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])

  organizationId Int
  messages       Message[]
  members        GroupMember[]
}

model GroupMember {
  user     User     @relation(fields: [userId], references: [id])
  userId   Int
  group    Group    @relation(fields: [groupId], references: [id])
  groupId  Int
  role     Role     @default(MEMBER)
  joinedAt DateTime @default(now())
  @@id([userId, groupId])
}

model Conversation {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  participants ConversationMember[]
  messages     Message[]
  groups       Group[]
}

model ConversationMember {
  user   User @relation(fields: [userId], references: [id])
  userId Int

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId Int

  @@id([userId, conversationId])
}
